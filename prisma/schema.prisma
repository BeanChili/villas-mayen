// Villas Mayen — Schema v2 (Reunión 2)
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USUARIOS ====================

model User {
  id        String   @id @default(cuid())
  name      String
  username  String   @unique
  password  String
  email     String?
  phone     String?
  role      String   @default("VISUAL")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== CLIENTES ====================

model Client {
  id               String    @id @default(cuid())
  name             String
  clientType       String    // PARTICULAR, EMPRESA, IGLESIA, INSTITUCION
  category         String    @default("REGULAR") // BUENO, REGULAR, DELICADO, EN_OBSERVACION
  phone            String?
  email            String?
  address          String?
  rfc              String?
  observations     String?
  registrationDate DateTime  @default(now())
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  quotes       Quote[]
}

// ==================== UBICACIONES (unificadas) ====================

model Location {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // FREE_AREA, DINING_ROOM, HALL, GARDEN, TERRACE
  capacity    Int?
  description String?
  unitPrice   Float    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== HABITACIONES ====================

model Building {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floors Floor[]
}

model Floor {
  id         String   @id @default(cuid())
  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  level      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rooms Room[]

  @@unique([buildingId, level])
}

model Room {
  id             String   @id @default(cuid())
  floorId        String
  floor          Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  number         String
  capacity       Int?
  bedType        String?
  pricePerNight  Float?
  pricePerPerson Float?
  status         String   @default("DISPONIBLE") // DISPONIBLE, RESERVADA, OCUPADA, MANTENIMIENTO
  photo          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([floorId, number])
}

// ==================== COTIZACIONES ====================

model Quote {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])

  // Datos del evento
  eventTitle    String?   // "Boda Claudia"
  eventDate     DateTime
  endDate       DateTime?

  // Moneda
  currency      String    @default("GTQ") // GTQ, USD
  exchangeRate  Float     @default(1)

  // Asistentes
  guestCount    Int?

  // Estados y flujo
  status        String    @default("BORRADOR") // BORRADOR, ENVIADA, NO_CONFIRMADA, CONFIRMADA, EN_EJECUCION, CANCELADO, FINALIZADA
  sentAt        DateTime?
  confirmedAt   DateTime?
  executedAt    DateTime?
  finishedAt    DateTime?
  cancelledAt   DateTime?

  // Estados de pago
  paymentStatus     String    @default("SIN_PAGO") // SIN_PAGO, PARCIAL, PAGADO
  paidAmount        Float     @default(0)
  pendingAmount     Float     @default(0)
  confirmationDate  DateTime?
  executionDate     DateTime?
  completionDate    DateTime?

  // Totales
  subtotal      Float     @default(0)
  discountType  String?   // PERCENT, FIXED
  discountValue Float     @default(0)
  totalAmount   Float     @default(0)

  // Notas
  notes             String?
  decorationPhotos  String?
  parkingSpot       String?    // Parqueo: "Predio", "4", "3", etc.

  // Items, espacios, pagos, gastos, cierres
  items         QuoteItem[]
  spaces        QuoteSpace[]
  emailLogs     EmailLog[]
  payments      Payment[]
  expenses      Expense[]
  eventClosing  EventClosing?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, eventDate])
}

model QuoteSpace {
  id           String   @id @default(cuid())
  quoteId      String
  quote        Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  locationType String   // FREE_AREA, DINING_ROOM, HALL, ROOM, GARDEN, TERRACE
  locationId   String
  locationName String

  startTime    String   // "14:30" — fuente de verdad
  endTime      String   // "16:45"

  pricingMode  String   @default("PER_SPACE") // PER_PERSON, PER_SPACE
  unitPrice    Float    @default(0)
  totalPrice   Float    @default(0)
  adjustmentType String? @default("DISCOUNT") // DISCOUNT, SURCHARGE

  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([quoteId])
  @@index([locationType, locationId])
}

model QuoteItem {
  id          String    @id @default(cuid())
  quoteId     String
  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])

  furnitureId String?
  furniture   Furniture? @relation(fields: [furnitureId], references: [id])

  name        String
  category    String

  // Menú y tipo de invitado
  menuNumber   Int?
  guestType    String?   // ADULTO, NINO

  // Precio base
  unitPrice    Float
  pricingMode  String?   // PER_PERSON, PER_SPACE, PER_UNIT

  // Descuento por ítem
  discountType  String?  // PERCENT, FIXED
  discountValue Float    @default(0)
  adjustmentType String? @default("DISCOUNT") // DISCOUNT, SURCHARGE

  notes        String?

  // Cantidades por día (relación con QuoteItemDay)
  dailyQuantities QuoteItemDay[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model QuoteItemDay {
  id          String   @id @default(cuid())
  quoteItemId String
  quoteItem   QuoteItem @relation(fields: [quoteItemId], references: [id], onDelete: Cascade)
  
  date        DateTime // Fecha específica
  quantity    Int      // Cantidad para ese día
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([quoteItemId, date])
}

// ==================== PAGOS ====================

model Payment {
  id            String      @id @default(cuid())
  quoteId       String?
  quote         Quote?      @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  amount        Float
  currency      String      @default("GTQ") // GTQ, USD
  exchangeRate  Float?
  amountGTQ     Float?      // equivalente en quetzales
  paymentType    String      @default("EFECTIVO") // EFECTIVO, DEPOSITO, TRANSFERENCIA, CHEQUE, TARJETA
  referenceNumber String?

  notes         String?
  createdByName String
  createdAt     DateTime    @default(now())
}

// ==================== PRODUCTOS ====================

model Product {
  id            String   @id @default(cuid())
  name          String
  category      String   // COMIDA_MENU, ADORNOS_DECORACION, SERVICIOS_ADICIONALES, PLATOS, CUBIERTOS, PICHELES, VASOS, COPAS
  menuType      String?  // DESAYUNO, REFACCION, COFFEE_BREAK, ALMUERZO, CENA
  unitPrice     Float
  description   String?
  photo         String?
  available     Boolean  @default(true)
  unitMeasure   String   // PIEZA, PERSONA, HORA, EVENTO
  quantity      Int      @default(0)
  isFree        Boolean  @default(false)
  pricePerDay   Float?
  pricePerHour  Float?
  rentalPrice   Float     @default(0)
  color         String?  // ej: azul, rojo
  packageSize   Int?     // unidades por paquete, ej: Tazas x50

  quoteItems    QuoteItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, category])
}

// ==================== TIPO DE CAMBIO ====================

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String   @default("USD")
  toCurrency   String   @default("GTQ")
  rate         Float
  updatedBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== MOBILIARIO/INVENTARIO ====================

model Furniture {
  id               String   @id @default(cuid())
  inventoryNumber  String   @unique
  name             String
  category         String   // SILLAS, MESAS, MANTELES, VAJILLA, CRISTALERIA, CUBERTERIA, DECORACION, EQUIPOS_SONIDO, ILUMINACION, CARPAS, OTROS
  purchaseValue    Float
  depreciationRate Float
  currentValue     Float
  rentalPrice      Float    @default(0) // Precio de alquiler para cotizaciones
  status           String   @default("BUENO") // BUENO, REGULAR, DANADO, DADO_BAJA
  color             String?   // ej: azul, rojo
  photo            String?
  purchaseDate     DateTime?
  location         String?
  observations     String?

  assignedEvents   EventClosingItem[]
  quoteItems       QuoteItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==================== GASTOS ====================

model Expense {
  id             String      @id @default(cuid())
  date           DateTime
  category       String      // MANTENIMIENTO, SERVICIOS, SUELDOS, INSUMOS, DECORACION, TRANSPORTE, OTROS
  description    String
  amount         Float
  receiptPhoto   String?
  quoteId        String?
  quote          Quote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// ==================== CIERRE DE EVENTOS ====================

model EventClosing {
  id            String      @id @default(cuid())
  quoteId       String      @unique
  quote         Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  closingDate   DateTime
  returnStatus  String      // COMPLETO, CON_DANOS, CON_PERDIDAS
  observations  String?
  damageCost    Float       @default(0)
  lossCost      Float       @default(0)

  items         EventClosingItem[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model EventClosingItem {
  id                String        @id @default(cuid())
  eventClosingId    String
  eventClosing      EventClosing  @relation(fields: [eventClosingId], references: [id], onDelete: Cascade)
  furnitureId       String?
  furniture         Furniture?    @relation(fields: [furnitureId], references: [id])

  // Para items que no son mobiliario (productos generales)
  itemName          String?
  quantity          Int           @default(1)

  returnStatus      String        // RETORNADO_OK, RETORNADO_DANADO, NO_RETORNADO
  damageDescription String?
  damagePhoto       String?
  repairCost        Float         @default(0)
  notes             String?
}

// ==================== CIERRES DIARIOS ====================

model DailyClosing {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalEvents     Int
  completedEvents Int
  totalCollected  Float
  pendingAmount   Float
  incidents       String?
  createdBy       String
  createdAt       DateTime @default(now())
}

// ==================== EMAIL LOG ====================

model EmailLog {
  id       String   @id @default(cuid())
  quoteId  String?
  quote    Quote?   @relation(fields: [quoteId], references: [id])
  type     String   // SENT_TO_CLIENT, SENT_TO_ACCOUNTING, RESENT
  sentTo   String
  sentBy   String
  sentAt   DateTime @default(now())
  status   String   @default("SENT") // SENT, FAILED
  error    String?
}

// ==================== PERMISOS ====================

model Permission {
  id         String  @id @default(cuid())
  role       String
  module     String
  canCreate  Boolean @default(false)
  canRead    Boolean @default(false)
  canUpdate  Boolean @default(false)
  canDelete  Boolean @default(false)
  canApprove Boolean @default(false)

  @@unique([role, module])
}

// ==================== CATEGORÍAS EDITABLES ====================

model Category {
  id        String   @id @default(cuid())
  name      String
  type      String   // PRODUCT, FURNITURE
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type])
}
